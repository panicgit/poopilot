<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="horizontal">

    <!-- Left Panel: Countdown -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTimeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="도착까지"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvTimeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="--"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_countdown"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDistValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="-- 남음"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_title" />

            <TextView
                android:id="@+id/tvTbtDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/accent_purple"
                android:textSize="@dimen/text_body_small"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- Right Panel: Controls -->
    <LinearLayout
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNavLogo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Poopilot"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:background="?attr/selectableItemBackground"
                android:gravity="center"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:text="취소"
                android:textColor="@color/emergency_red"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Destination Card -->
        <LinearLayout
            android:id="@+id/destCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_large">

            <TextView
                android:id="@+id/tvDestName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목적지"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDestAddr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="주소"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <!-- Door Unlock -->
        <TextView
            android:id="@+id/btnDoorUnlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/door_unlock_bg"
            android:gravity="center"
            android:minHeight="@dimen/touch_target_min"
            android:text="🔓 도착 시 도어 자동 언락"
            android:textColor="@color/success_green"
            android:textSize="@dimen/text_body_small" />

        <!-- Change Route -->
        <TextView
            android:id="@+id/btnChangeRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/card_bg"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:minHeight="@dimen/touch_target_min"
            android:text="더 가까운 곳으로 변경"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body_small" />
    </LinearLayout>
</LinearLayout>
