          "dataSource": "SearchViewModel.isLoading (LiveData<Boolean>)",
          "sourceFile": "SearchFragment.kt:97"
        },
        {
          "viewId": "tvSearchSub",
          "property": "visibility",
          "conditions": [
            { "when": "isLoading == true", "value": "VISIBLE" },
            { "when": "isLoading == false", "value": "GONE" }
          ],
          "dataSource": "SearchViewModel.isLoading (LiveData<Boolean>)",
          "sourceFile": "SearchFragment.kt:98"
        },
        {
          "viewId": "rvResults",
