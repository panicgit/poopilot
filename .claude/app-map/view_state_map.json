          ],
          "dataSource": "MainViewModel.recentVisits (LiveData<List<FavoriteRestroom>>)",
          "sourceFile": "MainFragment.kt:142-146"
        },
        {
          "viewId": "tvRecentEmpty",
          "property": "visibility",
